{
  "name": "remote-notifier-codex-router",
  "displayName": "Remote Notifier Codex (Router)",
  "description": "Route OpenAI Codex CLI hooks from local or Remote SSH workspaces to persistent Windows notifications with click-to-focus session navigation",
  "version": "1.0.10",
  "publisher": "ddyndo",
  "author": "Damian Dyńdo",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Kirito-Elucidator/Codex-Remote-Notifier"
  },
  "homepage": "https://github.com/Kirito-Elucidator/Codex-Remote-Notifier#readme",
  "bugs": {
    "url": "https://github.com/Kirito-Elucidator/Codex-Remote-Notifier/issues"
  },
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "notifications",
    "openai-codex",
    "codex-cli",
    "ai-agent",
    "vscode-extension",
    "system",
    "native",
    "app",
    "remote",
    "ssh",
    "remote-ssh",
    "windows-notifications",
    "productivity",
    "container",
    "docker",
    "notification",
    "center",
    "toast",
    "balloon",
    "growl"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:remoteNotifier.focusCodexSession"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "remoteNotifier.ensureRouterStarted",
        "title": "Remote Notifier: Ensure Router extension started (internal command)"
      },
      {
        "command": "remoteNotifier.showSessionInfo",
        "title": "Remote Notifier: Show session info"
      },
      {
        "command": "remoteNotifier.regenerateToken",
        "title": "Remote Notifier: Regenerate token"
      },
      {
        "command": "remoteNotifier.copyNotifyCommand",
        "title": "Remote Notifier: Copy Notify command"
      },
      {
        "command": "remoteNotifier.installScript",
        "title": "Remote Notifier: Install code-notify command in current workspace"
      },
      {
        "command": "remoteNotifier.autoConfigure",
        "title": "Remote Notifier: Auto-configure notifications in current workspace for..."
      },
      {
        "command": "remoteNotifier.removeCodexConfiguration",
        "title": "Remote Notifier: Remove Codex notification hooks"
      }
    ],
    "configuration": {
      "title": "Remote Notifier (Router)",
      "properties": {
        "remoteNotifier.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable the notification server."
        },
        "remoteNotifier.port": {
          "type": "integer",
          "default": 0,
          "description": "Fixed port for the notification server. 0 = auto-assign."
        },
        "remoteNotifier.maxBodySize": {
          "type": "integer",
          "default": 65536,
          "description": "Maximum request body size in bytes."
        },
        "remoteNotifier.notificationLevel": {
          "type": "string",
          "enum": [
            "information",
            "warning",
            "error"
          ],
          "default": "information",
          "description": "Default notification level when not specified in the request."
        },
        "remoteNotifier.showTimestamp": {
          "type": "boolean",
          "default": false,
          "description": "Prepend a timestamp to notification messages."
        },
        "remoteNotifier.codexPreviewLength": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "default": 16,
          "description": "Maximum visible characters used for each Codex session name and answer preview."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run build && npx @vscode/vsce package --no-dependencies"
  },
  "dependencies": {
    "remote-notifier-shared": "*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "vitest": "^4.1.5"
  }
}
